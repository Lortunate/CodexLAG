{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "CodexLAG",
  "version": "0.1.0",
  "identifier": "com.example.codexlag",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodexLAG",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
